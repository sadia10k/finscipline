# Finscipline environment — copy this file to .env and fill in your values
# DO NOT commit .env to version control

# Required: your OpenAI API key (needs access to gpt-4o-mini and text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Required: session signing secret — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Optional: logging level — DEBUG | INFO | WARNING | ERROR  (default: INFO)
# Set DEBUG to see every tool call and agent iteration in logs/app.log
LOG_LEVEL=INFO
